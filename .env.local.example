# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it's in .gitignore.

# === Sanity (required) ===
# Get from sanity.io/manage after creating your project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# === Sanity write token (only needed for the seed script) ===
# Create at sanity.io/manage → API → Tokens. Permission: Editor.
# Used only by scripts/seed.mjs. Do NOT use NEXT_PUBLIC_ prefix.
SANITY_WRITE_TOKEN=

# === Sanity read token (optional) ===
# Only needed if you switch perspective to draft previews. Default site reads use the CDN.
SANITY_API_READ_TOKEN=

# === Revalidation webhook secret ===
# Random string. Set the same value in Sanity → API → Webhooks → Secret.
SANITY_REVALIDATE_SECRET=
